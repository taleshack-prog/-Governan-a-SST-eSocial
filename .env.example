# ==============================================================
# SST ESOCIAL GOV — Variáveis de Ambiente
# Projeto: Governança SST/eSocial com IA
# Arquivo: .env.example  (copie para .env e preencha os valores)
# PORTA BACKEND : 8001  (não conflita com outros projetos)
# PORTA FRONTEND: 3001
# PORTA DB      : 5433
# PORTA REDIS   : 6380
# ==============================================================

# ---- APLICAÇÃO ----
APP_NAME="SST eSocial Gov"
APP_ENV=development
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_DE_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ---- BANCO DE DADOS ----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sst_esocial_db
POSTGRES_USER=sst_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- REDIS ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ---- CELERY ----
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ---- IA / LLM ----
# OpenRouter (recomendado: custo menor, múltiplos modelos)
OPENROUTER_API_KEY=sk-or-TROQUE_PELA_SUA_CHAVE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-haiku-4-5
LLM_FALLBACK_MODEL=openai/gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ---- EMBEDDINGS ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---- STORAGE (MinIO / S3) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=sst_minio_user
MINIO_SECRET_KEY=TROQUE_POR_SENHA_FORTE
MINIO_BUCKET=sst-documents
MINIO_SECURE=false

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3001","http://localhost:3000"]

# ---- LOGS ----
LOG_LEVEL=INFO
LOG_FORMAT=json
